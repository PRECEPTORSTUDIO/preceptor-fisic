# ─────────────────────────────────────────────
# Preceptor Fisic — env vars
# Copie pra .env.local e preencha
# ─────────────────────────────────────────────

# Supabase (projeto BR — sa-east-1 / São Paulo)
PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# DB — pegue em Supabase Dashboard > Settings > Database
# Transaction pooler (porta 6543) — pra runtime
DATABASE_URL=postgresql://postgres.xxxxx:PASS@aws-1-sa-east-1.pooler.supabase.com:6543/postgres
# Session mode (porta 5432) — só pra migrations
DATABASE_URL_DIRECT=postgresql://postgres.xxxxx:PASS@aws-1-sa-east-1.pooler.supabase.com:5432/postgres
# Máx. de conexões por instância (opcional). Default 3 — bom pra serverless.
# Suba só se rodar num servidor Node persistente. Em serverless, valores
# altos × muitas instâncias estouram o limite do pooler → 500 intermitente.
# DB_POOL_MAX=3

# Anthropic (Claude) — GERAÇÃO dos planos e resumos. sk-ant-api03-...
ANTHROPIC_API_KEY=

# Modelo do caminho primário (streaming, o que o cliente vê enquanto gera).
# Default no código já é claude-sonnet-5 (rápido). Setar aqui só pra sobrescrever:
# claude-opus-4-8 (mais profundo/lento) ou claude-haiku-4-5 (mais barato).
AI_MODEL_FAST=claude-sonnet-5

# Gemini — SÓ embeddings do RAG (base embedada com gemini-embedding-001;
# trocar exige re-embedar os 2.040 chunks). Não remover.
GOOGLE_GENERATIVE_AI_API_KEY=AI...

# Email transactional (Resend) — opcional em dev/staging.
# Sem RESEND_API_KEY o app loga warnings em vez de enviar email.
# Crie key gratuita em https://resend.com (100 emails/dia free).
RESEND_API_KEY=re_...
# From: precisa estar verificado no Resend OU usar o sandbox onboarding@resend.dev
RESEND_FROM=Preceptor Fisic <noreply@seu-dominio.com>

# App URL — usado em links de email, magic-links e no redirectTo do reset de
# senha (garante URL estável mesmo acessando por preview/*.vercel.app)
PUBLIC_APP_URL=https://preceptor-fisic.vercel.app

# Secret dedicado dos magic-links do aluno (/a/[id]?t=...). Gere com:
#   openssl rand -hex 32
# Sem ele, cai no fallback SHA-256(SUPABASE_SERVICE_ROLE_KEY). Trocar o
# secret invalida TODOS os links já enviados — reenvie pelos profissionais.
ALUNO_LINK_SECRET=

# Bypass do token do aluno em DEV local (abre /a/[id] sem ?t=). Exige build
# de dev E este opt-in explícito — nunca setar em produção.
ALUNO_LINK_DEV_BYPASS=1

# Sentry (opcional) — error tracking. Sem isso vira no-op.
# Pegue em sentry.io > Settings > Projects > [seu projeto] > Client Keys (DSN)
PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Plausible analytics (opcional) — privacy-first, sem cookies
PUBLIC_PLAUSIBLE_DOMAIN=preceptor-fisic.vercel.app

# Quem recebe o alerta de venda do EBOOK pra liberar o Drive (default:
# castroomath7@gmail.com). Coloque o email do Jonas aqui.
EBOOK_NOTIFY_EMAIL=

# Asaas (billing dos planos) — chave de API de PRODUÇÃO ($aact_prod_...).
# Painel: Asaas > Integrações > Chaves de API. NUNCA commitar/logar.
ASAAS_API_KEY=
# Token combinado na config do webhook (Asaas envia no header
# asaas-access-token; o endpoint /api/webhooks/asaas valida). Gere com:
#   openssl rand -hex 32
ASAAS_WEBHOOK_TOKEN=
